# AER Environment Configuration
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to git — it is listed in .gitignore.

# Earthdata credentials (for NASA data access)
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

# EODC STAC API endpoint
EODC_API_URL=https://stac.eodc.eu/api/v1

# Satpy caching configuration
SATPY_CACHE_DIR=satpy_cache
SATPY_CACHE_SENSOR_ANGLES=False
SATPY_CACHE_LONLATS=True

# CDSE S3 credentials (for Copernicus Data Space Ecosystem)
CDSE_S3_ACCESS_KEY=your_cdse_s3_access_key
CDSE_S3_SECRET_KEY=your_cdse_s3_secret_key
CDSE_USER=your_cdse_email
CDSE_PASSWORD=your_cdse_password

# Data store paths
GRID_STORE_PATH=/path/to/grid/store
AOD_STORE_PATH=/path/to/aod/store
